<li data-index="{{index}}">
    <div class="key">
        <select class="change-category">
        {{#each groupedChangeKeys as |options groupLabel|}}
            <option value="{{groupLabel}}" {{#if (eq groupLabel @root.selectedCategory)}}selected{{/if}}>
                {{groupLabel}}
            </option>
        {{/each}}
        </select>

        <select name="{{change.keyPath}}" class="change-key">
        {{#each selectedKeyOptions as |opt|}}
            <option value="{{opt.key}}" {{#if (eq opt.key @root.change.key)}}selected{{/if}}>
                {{opt.label}}
            </option>
        {{/each}}
        </select>
    </div>

    <div class="type">
        {{formInput fields.type name=change.typePath value=change.type choices=changeTypes}}
    </div>

    <div class="value">
        {{formInput fields.value name=change.valuePath value=change.value elementType="input"}}
    </div>

    <input type="hidden" name="{{change.phasePath}}" value="{{change.phase}}">

    <div class="priority">
        {{formInput fields.priority name=change.priorityPath value=change.priority placeholder=defaultPriority}}
    </div>

    <div class="controls">
        <button type="button" class="inline-control icon fa-solid fa-trash" data-action="deleteChange"></button>
    </div>
</li>